{
  "name": "eclean-mobile",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "jest --projects jest.screens.config.js --no-coverage",
    "test:unit": "jest tests/unit --no-coverage",
    "test:integration": "TEST_API_URL=https://ecleanfuture-production.up.railway.app/api/v1 jest tests/integration --no-coverage",
    "test:screens": "jest --config jest.screens.config.js --no-coverage",
    "test:screens:watch": "jest --config jest.screens.config.js --watch",
    "test:all": "jest tests/unit --no-coverage && jest --config jest.screens.config.js --no-coverage && TEST_API_URL=https://ecleanfuture-production.up.railway.app/api/v1 jest tests/integration --no-coverage",
    "test:coverage": "jest --config jest.screens.config.js --coverage"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@gorhom/bottom-sheet": "^5.0.6",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-query-persist-client": "^5.59.0",
    "axios": "^1.7.7",
    "expo": "^54.0.0",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "~15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "lucide-react-native": "^0.456.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "socket.io-client": "^4.7.5",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "axios-mock-adapter": "^2.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "^18.3.1",
    "typescript": "^5.3.3"
  },
  "jest": {
    "projects": [
      {
        "displayName": "unit",
        "testEnvironment": "node",
        "testMatch": [
          "<rootDir>/tests/unit/**/*.test.ts",
          "<rootDir>/tests/integration/**/*.test.ts"
        ],
        "transform": {
          "^.+\\.(t|j)sx?$": [
            "babel-jest",
            {
              "configFile": "./babel.config.js"
            }
          ]
        },
        "moduleNameMapper": {
          "^@/(.*)$": "<rootDir>/src/$1",
          "^expo-secure-store$": "<rootDir>/tests/__mocks__/expo-secure-store.ts",
          "^expo-constants$": "<rootDir>/tests/__mocks__/expo-constants.ts",
          "^@react-native-community/netinfo$": "<rootDir>/tests/__mocks__/netinfo.ts",
          "^.*/navigation/navigationRef$": "<rootDir>/tests/__mocks__/navigationRef.ts",
          "^react-native$": "<rootDir>/tests/__mocks__/react-native.ts"
        },
        "transformIgnorePatterns": [
          "node_modules/(?!(axios|zustand|@tanstack))"
        ]
      },
      {
        "displayName": "screens",
        "testEnvironment": "node",
        "testMatch": [
          "<rootDir>/tests/screens/**/*.test.tsx"
        ],
        "setupFiles": [
          "<rootDir>/tests/setup.screens.js"
        ],
        "transform": {
          "^.+\\.(t|j)sx?$": [
            "babel-jest",
            {
              "configFile": "./babel.config.js"
            }
          ]
        },
        "transformIgnorePatterns": [
          "node_modules/(?!(react-native|@react-native|@react-navigation|expo-linear-gradient|expo-secure-store|expo-location|expo-notifications|expo-task-manager|expo-camera|expo-image-picker|expo-constants|expo-device|expo-haptics|expo-splash-screen|expo-status-bar|lucide-react-native|react-native-svg|react-native-reanimated|react-native-gesture-handler|react-native-safe-area-context|react-native-screens|react-native-maps|@gorhom|socket.io-client|zustand|@tanstack|axios))"
        ],
        "moduleNameMapper": {
          "^@/(.*)$": "<rootDir>/src/$1"
        }
      }
    ]
  },
  "private": true
}
