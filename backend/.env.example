# ── App ────────────────────────────────────────────────────────────────────────
# NODE_ENV: "development" | "production" | "test"
NODE_ENV=development

# PORT: HTTP port the Fastify server listens on
PORT=3000

# ── Database ────────────────────────────────────────────────────────────────────
# DATABASE_URL: Full PostgreSQL connection string (docker-compose default below)
# NOTE: Docker runs on port 5433 (local postgres may occupy 5432)
DATABASE_URL=postgresql://eclean:eclean_dev@localhost:5433/eclean_dev

# ── Redis ────────────────────────────────────────────────────────────────────────
# REDIS_URL: Redis connection string — used by BullMQ job queues and caching
REDIS_URL=redis://localhost:6379

# ── Auth ────────────────────────────────────────────────────────────────────────
# JWT_ACCESS_SECRET: Signs access tokens (15m). Min 32 chars. Generate: openssl rand -base64 48
JWT_ACCESS_SECRET=REPLACE_THIS_min_32_chars_generate_with_openssl_rand_-base64_48

# JWT_REFRESH_SECRET: Signs refresh tokens (7d). MUST differ from access secret.
JWT_REFRESH_SECRET=REPLACE_THIS_min_32_chars_generate_with_openssl_rand_-base64_48

# BCRYPT_ROUNDS: Password hashing cost factor. 12 = ~250ms/hash (good for prod)
BCRYPT_ROUNDS=12

# ── Cloudinary (photo uploads) ──────────────────────────────────────────────────
# Get these from: https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Anthropic (Claude Vision AI verification) ───────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Razorpay (payments & payouts) ───────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Set RAZORPAY_KEY_ID=test_mode to skip real API calls during development
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Get from: https://dashboard.razorpay.com → Settings → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=

# ── Email (Resend) ──────────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=

# ── Firebase (push notifications) ───────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Service Accounts → Generate key
# Paste the full JSON as a single-line string (use: cat key.json | tr -d '\n')
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── CORS & URLs ─────────────────────────────────────────────────────────────────
# CORS_ORIGINS: Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3001

# FRONTEND_URL: Used for redirect links in emails
FRONTEND_URL=http://localhost:3001

# ── Monitoring ───────────────────────────────────────────────────────────────────
# SENTRY_DSN: Get from https://sentry.io → Project → Settings → Client Keys

SENTRY_DSN=https://3df1f79871dd2ef6f271d3ea66e59f76@o4511106441871360.ingest.de.sentry.io/4511106452881488
